<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cyc.xiangwei.order.dao.OrderMapper">

    <resultMap id="BaseResultMap" type="com.cyc.xiangwei.order.entity.Order">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="merchant_id" property="merchantId"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findOrderWithItemsByProductName" resultMap="BaseResultMap">
        SELECT DISTINCT o.*
        FROM orders o
        LEFT JOIN order_item oi ON o.id = oi.order_id
        WHERE o.user_id = #{userId}
        <if test="productName != null and productName != ''">
            AND oi.product_name LIKE CONCAT('%', #{productName}, '%')
        </if>
        ORDER BY o.create_time DESC
    </select>

</mapper>
